name: Build Android APK  # اسم المهمة
on:
  workflow_dispatch:     # زر التشغيل اليدوي

jobs:
  build:
    runs-on: ubuntu-latest  # يخدم على سيرفر لينكس
    
    steps:
    - name: تحميل الكود
      uses: actions/checkout@v4  # يجيب الكود من GitHub
      
    - name: تنصيب Node.js
      uses: actions/setup-node@v4
      with:
        node-version: '24'  # اصدار النود
        
    - name: تنصيب المكتبات
      run: npm install  # ينزل node_modules
      
    - name: بناء الموقع
      run: npm run build  # يبني مجلد build
      
    - name: اضافة الاندرويد
      run: npx cap add android  # يضيف منصة الاندرويد
      
    - name: مزامنة الكود
      run: npx cap sync  # ينقل ملفات build للاندرويد
      
    - name: بناء ملف APK
      run: cd android && ./gradlew assembleDebug  # يبني الAPK
      
    - name: رفع ملف APK
      uses: actions/upload-artifact@v4
      with:
        name: app-debug  # اسم الملف اللي بينزل
        path: android/app/build/outputs/apk/debug/app-debug.apk  # مكان الAPK
