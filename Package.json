name: Build APK
on:
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: تحميل الكود
        uses: actions/checkout@v4

      - name: تنصيب Node
        uses: actions/setup-node@v4
        with:
          node-version: '24'

      - name: تنصيب المكتبات
        run: npm install

      - name: بناء الموقع
        run: npm run build

      - name: اضافة الاندرويد
        run: npx cap add android

      - name: مزامنة
        run: npx cap sync

      - name: بناء الAPK
        run: cd android && ./gradlew assembleDebug

      - name: رفع الملف
        uses: actions/upload-artifact@v4
        with:
          name: app-debug
          path: android/app/build/outputs/apk/debug/app-debug.apk
